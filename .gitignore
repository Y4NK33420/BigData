# ─────────────────────────────────────────────────────────────
#  Environment & Secrets
# ─────────────────────────────────────────────────────────────
.env
.env.*
!.env.example

# ─────────────────────────────────────────────────────────────
#  Data (Medallion layers — generated at runtime)
# ─────────────────────────────────────────────────────────────
data/bronze/youtube/*
data/bronze/reddit/*
data/silver/**
data/gold/**
# Keep directory structure via .gitkeep
!data/**/.gitkeep

# ─────────────────────────────────────────────────────────────
#  Python
# ─────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.egg-info/
dist/
build/
*.egg
.eggs/
*.pyc
.Python
env/
venv/
.venv/
pip-log.txt
pip-delete-this-directory.txt
.tox/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.hypothesis/
htmlcov/
.coverage
.coverage.*
coverage.xml

# ─────────────────────────────────────────────────────────────
#  Node / React frontend
# ─────────────────────────────────────────────────────────────
frontend/node_modules/
frontend/dist/
frontend/.vite/
frontend/.cache/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm

# ─────────────────────────────────────────────────────────────
#  Docker
# ─────────────────────────────────────────────────────────────
*.log

# ─────────────────────────────────────────────────────────────
#  OS junk
# ─────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
*~

# ─────────────────────────────────────────────────────────────
#  IDE
